{
  "id": "apaf.security",
  "name": "Security handler for APAF",
  "version": "1.0.0",
  "plugin": "plugin.js",
  "requires": [
  	{"type": "plugin","id": "npa.core","version": "1.0.0"},
  	{"type": "plugin","id": "npa.logging","version": "1.0.0"},
  	{"type": "plugin","id": "npa.http","version": "1.0.0"},
  	{"type": "plugin","id": "npa.telemetry","version": "1.0.0"},
  	{"type": "plugin","id": "apaf.datatype","version": "1.0.0"}
  ],
  "extends": [
  	{
  		"point": "npa.log.provider",
  		"id": "apaf.security.logger",
  		"dir": "apaf.security"
  	},
  	{
  		"point": "npa.core.service",
  		"id": "apaf.security.service",
  		"service": "apaf-security"
  	},
  	{
  		"point": "npa.http.router",
  		"id": "apaf.security.router",
  		"path": "/apaf-security"
  	},
  	{
  		"point": "npa.telemetry.dimension.provider",
  		"id": "apaf.security.telemetry.provider",
		"name": "secure.api.call",
		"displayLabel": "Secured API Calls",
		"description": "Total number of secured API call",
		"type": "int",
		"unit": "",
		"maxPoints": 60
  	},
  	{
  		"point": "npa.http.handler",
  		"id": "apaf.security.generate.api.key.handler",
  		"router": "apaf.security.router",
  		"method": "GET",
  		"schema": "/getApiKey",
  		"handler": "generateApiKeyHandler",
  		"securityRole": "operator",
		"description": "Get a newly generated API key",
		"input": ""
  	}
  ],
  "provides": [
  ]
}