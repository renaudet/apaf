{
    "id": "wexToolbar",
    "version": "1.0.0",
    "type": "Toolbar",
    "configuration": {
        "actions": [
            {
                "label": "@apaf.workspace.explorer.toolbar.new.project",
                "actionId": "newProject",
                "icon": "/uiTools/img/silk/book_add.png",
                "enabled": true
            },
            {
                "label": "@apaf.workspace.explorer.toolbar.new.folder",
                "actionId": "newFolder",
                "icon": "/uiTools/img/silk/folder_add.png",
                "enabled": false
            },
            {
                "label": "@apaf.workspace.explorer.toolbar.new.file",
                "actionId": "newFile",
                "icon": "/uiTools/img/silk/page_add.png",
                "enabled": false
