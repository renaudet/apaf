{
  "id": "apaf.api.explorer",
  "name": "API Explorer plugin for APAF",
  "version": "1.0.0",
  "plugin": "plugin.js",
  "requires": [
  	{"type": "plugin","id": "npa.core","version": "1.0.0"},
  	{"type": "plugin","id": "npa.logging","version": "1.0.0"},
  	{"type": "plugin","id": "npa.ui.locale","version": "1.0.0"},
  	{"type": "plugin","id": "npa.http","version": "1.0.0"},
  	{"type": "plugin","id": "apaf.menu","version": "1.0.0"}
  ],
  "extends": [
  	{
  		"point": "npa.log.provider",
  		"id": "apaf.api.explorer.logger",
  		"dir": "apaf.api.explorer"
  	},
  	{
  		"point": "npa.http.static",
  		"id": "apaf.api.explorer.htdocs",
  		"path": "/apaf-api-explorer",
  		"localDir": "htdocs"
  	},
  	{
  		"point": "npa.ui.locale.provider",
  		"id": "apaf.api.explorer.locale.provider.enUS",
  		"path": "i18n/apaf_api_explorer_en-US.locale",
  		"locale": "en-US"
  	},
  	{
  		"point": "npa.ui.locale.provider",
  		"id": "apaf.api.explorer.locale.provider.en",
  		"path": "i18n/apaf_api_explorer_en-US.locale",
  		"locale": "en"
  	},
  	{
  		"point": "npa.ui.locale.provider",
  		"id": "apaf.api.explorer.locale.provider.frFR",
  		"path": "i18n/apaf_api_explorer_fr-FR.locale",
  		"locale": "fr-FR"
  	},
  	{
  		"point": "npa.ui.locale.provider",
  		"id": "apaf.api.explorer.locale.provider.fr",
  		"path": "i18n/apaf_api_explorer_fr-FR.locale",
  		"locale": "fr"
  	},
  	{
  		"point": "apaf.menu.item.provider",
  		"id": "apaf.api.explorer.menu.item",
  		"menu": "developmentMenuPlaceholder",
  		"securityRole": "developer",
  		"item": {
  			"id": "apiExplorer",
  			"label": "@apaf.api.explorer.menu.label",
  			"actionId": "redirect",
  			"icon": "/uiTools/img/silk/world_link.png",
  			"uri": "/apaf-api-explorer/html/apiExplorer.html"
  		}
  	}
  ],
  "provides": [
  ]
}
